# ── Telegram ──
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_admin_telegram_id

# ── Browser Pool ──
MAX_BROWSER_INSTANCES=5
BROWSER_WARMUP_COUNT=2
BROWSER_HEADLESS=true

# ── Booking Engine ──
MAX_RETRIES=3
BOOKING_TIMEOUT=60

# ── Cache TTLs (seconds) ──
CACHE_EVENT_TTL=3600
CACHE_SELECTOR_TTL=7200
CACHE_PRICE_TTL=300

# ── Seat Mapping Grid ──
SEAT_SCAN_GRID_X=22
SEAT_SCAN_GRID_Y=18

# ── Logging ──
LOG_LEVEL=INFO
